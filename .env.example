# Copiá a .env y ajustá

# API real (opcional en dev: si no definís VITE_BACKEND_URL, se usa calendario mock)
# VITE_BACKEND_URL=https://api.tu-backend.com

# Forzar mock aunque tengas VITE_BACKEND_URL (opcional)
# VITE_USE_MOCK_CALENDAR=true

# Vite usa el puerto 5160 (vite.config). Abrí:
# http://localhost:5160/mi-prueba
VITE_CALENDAR_SLUG=mi-prueba
